2. Plugin API — Patterns and Pitfalls


Always await async operations

// ✓ correct
const key = await figma.clientStorage.getAsync("api-key")
await figma.loadFontAsync({ family: "Inter", style: "Regular" })

// ✗ wrong — silent failure, no error thrown
figma.clientStorage.getAsync("api-key").then(...)  // fire-and-forget bug


Node traversal — performance first

// ✗ slow — traverses entire document
figma.currentPage.findAll(n => n.type === "TEXT")

// ✓ fast — use findAllWithCriteria when filtering by type
frame.findAllWithCriteria({ types: ["TEXT", "INSTANCE"] })

// ✓ always limit depth on large frames
function findWithDepth(node, predicate, maxDepth = 4, depth = 0) {
  if (depth > maxDepth) return []
  const results = []


Avoid blocking the main thread

// ✓ yield between expensive operations
for (const node of largeNodeList) {
  processNode(node)
  await new Promise(r => setTimeout(r, 0))  // let Figma breathe
}


absoluteBoundingBox — handle nulls

// absoluteBoundingBox is null for nodes inside collapsed components
// and for nodes not yet rendered
const box = node.absoluteBoundingBox
if (!box) return  // always guard


setPluginData vs setSharedPluginData

// setPluginData — only readable by THIS plugin
node.setPluginData("a11y.role", "button")

// setSharedPluginData — readable by any plugin + Figma REST API
// use this for data developers need to access externally
node.setSharedPluginData("a11y", "role", "button")
node.setSharedPluginData("a11y", "ariaLabel", "Submit form")


variantProperties vs componentPropertyDefinitions

// variantProperties — current instance's selected variants
// only available on INSTANCE nodes
if (node.type === "INSTANCE") {
  const variants = node.variantProperties  // { "State": "hover", "Size": "md" }
}

// componentPropertyDefinitions — the component's defined properties
// available on COMPONENT nodes
if (node.type === "COMPONENT") {
  const defs = node.componentPropertyDefinitions


